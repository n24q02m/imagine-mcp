{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.n24q02m/imagine-mcp",
  "description": "MCP server for image/video understanding & generation (Gemini/OpenAI/Grok)",
  "repository": {
    "url": "https://github.com/n24q02m/imagine-mcp.git",
    "source": "github"
  },
  "version": "1.4.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "imagine-mcp",
      "version": "1.4.0",
      "runtimeHint": "uvx",
      "runtimeArgs": [
        "--python",
        "3.13"
      ],
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GOOGLE_AI_STUDIO_API_KEY",
          "description": "Google AI Studio API key (aistudio.google.com/apikey)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API key (platform.openai.com)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "XAI_API_KEY",
          "description": "xAI (Grok) API key (console.x.ai)",
          "isRequired": false,
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "docker.io/n24q02m/imagine-mcp:latest",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GOOGLE_AI_STUDIO_API_KEY",
          "description": "Google AI Studio API key",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API key",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "XAI_API_KEY",
          "description": "xAI (Grok) API key",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
